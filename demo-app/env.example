# Finatic API Configuration
# Copy this file to .env.local and fill in your actual API keys

# API URL (usually localhost for development)
FINATIC_API_URL=http://localhost:8000

# Production API Key (starts with fntc_live_)
FINATIC_API_KEY=your_live_api_key_here

# Sandbox API Key (starts with fntc_sandbox_)
FINATIC_SANDBOX_API_KEY=your_sandbox_api_key_here

# Environment Selection is now controlled via the UI
# The demo app will default to sandbox mode for safety

# Next.js Public Variables (available in browser)
NEXT_PUBLIC_FINATIC_API_URL=http://localhost:8000

# Mock Mode Configuration (bypasses API entirely)
NEXT_PUBLIC_FINATIC_USE_MOCKS=false
NEXT_PUBLIC_FINATIC_MOCK_API_ONLY=false 