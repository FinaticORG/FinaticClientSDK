{
  "name": "@finatic/client",
  "version": "1.0.0",
  "description": "Finatic Client SDK for browser integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:integration": "FINATIC_INTEGRATION=1 jest tests/integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "format:check": "prettier --check src/**/*.ts",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "watch": "rollup -c -w"
  },
  "keywords": [
    "finatic",
    "trading",
    "finance",
    "api",
    "sdk",
    "typescript",
    "typescript"
  ],
  "author": {
    "name": "Finatic",
    "email": "support@finatic.dev"
  },
  "license": "PROPRIETARY",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FinaticORG/FinaticClientSDK.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "crypto-js": "^4.2.0",
    "p-retry": "^7.1.0",
    "uuid": "^13.0.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/crypto-js": "^4.2.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jest": "^30.1.3",
    "pg": "^8.16.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.53.3",
    "rollup-plugin-dts": "^6.3.0",
    "ts-jest": "^29.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.44.0"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "bugs": {
    "url": "https://github.com/FinaticORG/FinaticClientSDK/issues"
  },
  "homepage": "https://github.com/FinaticORG/FinaticClientSDK#readme",
  "overrides": {
    "brace-expansion": ">=2.0.3",
    "form-data": ">=4.0.6",
    "js-yaml@3": "3.15.0",
    "js-yaml@4": "4.3.0",
    "@babel/core": ">=7.29.6"
  }
}
