{
  "name": "@finatic/client",
  "version": "0.1.0",
  "description": "TypeScript SDK for Finatic Client API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "dev": "yarn build:watch",
    "demo:dev": "yarn workspace app dev",
    "demo:build": "yarn workspace app build",
    "demo:start": "yarn workspace app start"
  },
  "keywords": [
    "finatic",
    "trading",
    "finance",
    "api",
    "sdk",
    "typescript",
    "typescript"
  ],
  "author": "Finatic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FinaticORG/Client.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.0.0",
    "node-cache": "^1.0.0",
    "p-retry": "^1.0.0",
    "pino": "^1.0.0",
    "zod": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.5.0",
    "@types/node-cache": "^4.2.5",
    "@types/pino": "^7.0.5",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^30.1.3",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.44.0"
  },
  "private": true,
  "workspaces": [
    "demo-app"
  ]
}
